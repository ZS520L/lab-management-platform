# 复制为 .env 后按需修改
HOST=0.0.0.0
PORT=3000
SESSION_SECRET=[CHANGE_ME]

# 首次启动会自动创建管理员白名单账号
ADMIN_USER=admin

# 初始统一登录密码；管理员可在后台更新
SHARED_PASSWORD=[CHANGE_ME]

# 上传限制，单位 MB
MAX_UPLOAD_MB=200

# 数据、上传文件和预览缓存保存目录，默认相对于项目根目录
DATA_DIR=./data
UPLOAD_DIR=./storage/uploads
PREVIEW_DIR=./storage/previews

# Office 文件预览需要 LibreOffice/soffice 转 PDF。
# 如果系统 PATH 中没有 soffice，请填写 soffice.exe 的完整路径。
# Windows 示例：LIBREOFFICE_PATH=C:\\Program Files\\LibreOffice\\program\\soffice.exe
LIBREOFFICE_PATH=

# 公网部署配置
# 公网访问地址（用于启动提示）
PUBLIC_URL=
# 如果前面有 Nginx/反向代理且启用了 HTTPS，设为 true
COOKIE_SECURE=false
